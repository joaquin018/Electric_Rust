import { Button, VerticalBox, ScrollView } from "std-widgets.slint";
import { Toast } from "components/toast.slint";
import { BaseScreen } from "screens/base_screen.slint";
import { SideBar } from "components/sidebar.slint";

export component AppWindow inherits Window {
    title: "Construct";
    background: #121212;
    min-width: 360px;
    min-height: 640px;
    
    // Model and State
    in-out property <[string]> inv_vals: ["", "", "", "", "", "", "", "", "", "", "", "", "", "", "", "", ""];
    in-out property <int> active_idx: -1;
    
    // Toast State
    in-out property <bool> show_copy_toast: false;
    in-out property <int> toast_request_id: 0;

    // Sidebar State
    in-out property <bool> show_sidebar: false;
    callback request-copy();
    callback request-share();

    // Layout
    Rectangle {
        width: 100%;
        height: 100%;
        
        // Main Content (Base Screen)
        BaseScreen {
            width: 100%;
            height: 100%;
            inv_vals <=> root.inv_vals;
            active_idx <=> root.active_idx;
            menu-pressed => {
                root.show_sidebar = true;
            }
            request-copy => {
                root.request-copy();
            }
            request-share => {
                root.request-share();
            }
        }

        // Sidebar Navigation Drawer (Z-Index implicit by order, above BaseScreen)
        SideBar {
            open: root.show_sidebar;
            close-requested => {
                root.show_sidebar = false;
            }
            navigate-to(idx) => {
                // Handle navigation (Currently only 0=Base supported)
                if (idx == 0) {
                    root.show_sidebar = false;
                    // Already on Base, just close
                }
            }
        }

        // Global Toast (Overlay above everything)
        Toast {
            y: root.show_copy_toast ? parent.height - self.height : parent.height;
            animate y {
                duration: 250ms;
                easing: ease-out;
            }
            z: 200; // Explicitly above Sidebar
            message: "Copiado al portapapeles";
        }
    }
}
