import { Button, VerticalBox, ScrollView, LineEdit } from "std-widgets.slint";

export component InventoryItem inherits Rectangle {
    in property <string> label;
    in-out property <string> value;
    height: 85px;
    background: #1e1e1e;
    border-radius: 18px;
    HorizontalLayout {
        padding-left: 20px;
        padding-right: 20px;
        alignment: space-between;
        Text {
            text: label;
            color: #ffffff;
            vertical-alignment: center;
            font-size: 18px;
            font-weight: 500;
        }

        Rectangle {
            width: 100px;
            height: 45px;
            background: #121212;
            border-radius: 12px;
            y: (85px - 45px) / 2;
            
            // Border changes color and width when focused
            border-width: input.has-focus ? 1.5px : 0px;
            border-color: #ff9d00;
            
            // Placeholder "0" logic
            if (value == "" && !input.has-focus): Text {
                text: "0";
                color: #3b3b3b;
                font-size: 20px;
                font-weight: 800;
                vertical-alignment: center;
                horizontal-alignment: center;
            }
            input := TextInput {
                width: 100%;
                height: 100%;
                text <=> value;
                font-size: 20px;
                color: #ff9d00;
                selection-background-color: #ff9d0033; // Translucent orange selection
                vertical-alignment: center;
                horizontal-alignment: center;
                single-line: true;
                input-type: number;
            }

            // Area to easily focus the input
            TouchArea {
                clicked => {
                    input.focus();
                }
            }
        }
    }
}

export component SectionHeader inherits HorizontalLayout {
    in property <string> title;
    spacing: 12px;
    padding-top: 25px;
    padding-bottom: 15px;
    Rectangle {
        width: 4px;
        height: 24px;
        background: #ff9d00;
        border-radius: 2px;
    }

    Text {
        text: title;
        font-size: 20px;
        font-weight: 800;
        color: #ff9d00;
        vertical-alignment: center;
        letter-spacing: 1px;
    }
}

export component TopBar inherits Rectangle {
    height: 90px;
    background: #000000;
    VerticalLayout {
        padding-top: 30px;
        HorizontalLayout {
            padding-left: 15px;
            padding-right: 15px;
            alignment: space-between;
            Text {
                text: "←";
                font-size: 24px;
                color: #ffffff;
                vertical-alignment: center;
                width: 40px;
            }

            Text {
                text: "CONSTRUCT";
                font-size: 22px;
                font-weight: 900;
                color: #ffffff;
                vertical-alignment: center;
                horizontal-alignment: center;
                letter-spacing: 2px;
            }

            HorizontalLayout {
                spacing: 20px;
                width: 80px;
                alignment: end;
                Text {
                    text: "⛶";
                    font-size: 22px;
                    color: #ffffff;
                    vertical-alignment: center;
                }

                Text {
                    text: "≺";
                    font-size: 22px;
                    color: #ffffff;
                    vertical-alignment: center;
                }
            }
        }
    }
}

