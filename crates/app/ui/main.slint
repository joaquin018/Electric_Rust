import { Button, VerticalBox, ScrollView, LineEdit } from "std-widgets.slint";

export component InventoryItem inherits Rectangle {
    in property <string> label;
    in property <string> placeholder;
    in-out property <string> value;
    height: 60px;
    background: #2a2a2a;
    border-radius: 8px;
    HorizontalLayout {
        padding: 12px;
        spacing: 10px;
        alignment: space-between;
        Text {
            text: label;
            color: white;
            vertical-alignment: center;
            font-size: 16px;
        }

        LineEdit {
            placeholder-text: placeholder;
            text <=> value;
            width: 80px;
            horizontal-alignment: right;
            input-type: number;
        }
    }
}

export component SectionHeader inherits Rectangle {
    in property <string> title;
    height: 40px;
    Text {
        width: 100%;
        height: 100%;
        text: title;
        font-size: 20px;
        font-weight: 700;
        color: #ff9d00;
        vertical-alignment: bottom;
    }
}

export component AppWindow inherits Window {
    title: "Construct";
    background: @linear-gradient(180deg, #121212 0%, #000000 100%);
    ScrollView {
        VerticalBox {
            padding: 20px;
            spacing: 10px;
            alignment: start;

            // Header spacer replacing margin-bottom
            VerticalLayout {
                spacing: 10px;
                Text {
                    text: "CONSTRUCT";
                    font-size: 32px;
                    font-weight: 900;
                    color: white;
                    horizontal-alignment: center;
                }

                Rectangle {
                    height: 10px;
                }
            }

            SectionHeader {
                title: "Apoyos";
