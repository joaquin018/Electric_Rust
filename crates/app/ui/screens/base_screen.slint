import { Button, VerticalBox, ScrollView } from "std-widgets.slint";
import { InventoryItem } from "../components/inventory_item.slint";
import { LumberItem } from "../components/lumber_item.slint";
import { SectionHeader } from "../components/section_header.slint";
import { TopBar } from "../components/top_bar.slint";
import { NumericKeypad } from "../components/numeric_keypad.slint";

export component BaseScreen inherits Rectangle {
    in-out property <[string]> inv_vals;
    in-out property <[int]> inv_lengths; // indices parallel to inv_vals
    in-out property <int> active_idx;
    callback selective-share-pressed();
    callback full-share-pressed();

    callback request-activate-item(int);
    callback request-append-digit(string);
    callback request-set-length(int, int); // idx, length_idx
    callback request-backspace(); // New callback for Rust persistence

    VerticalLayout {
        TopBar {
            selective-share-pressed => {
                root.selective-share-pressed();
            }
            full-share-pressed => {
                root.full-share-pressed();
            }
        }

        Flickable {
            viewport-height: content.preferred-height;
            content := VerticalBox {
                padding-left: 16px;
                padding-right: 16px;
                padding-bottom: 350px;
                spacing: 12px;
                alignment: start;
                SectionHeader {
                    title: "APOYOS";
                }

                InventoryItem {
                    label: "30 cm";
                    value: root.inv_vals[0];
                    has-focus: root.active_idx == 0;
                    request-focus => {
                        root.request-activate-item(0);
                    }
                }

                InventoryItem {
                    label: "40 cm";
                    value: root.inv_vals[1];
                    has-focus: root.active_idx == 1;
                    request-focus => {
                        root.request-activate-item(1);
                    }
                }

                InventoryItem {
                    label: "50 cm";
                    value: root.inv_vals[2];
                    has-focus: root.active_idx == 2;
                    request-focus => {
                        root.request-activate-item(2);
                    }
                }

                InventoryItem {
                    label: "60 cm";
                    value: root.inv_vals[3];
                    has-focus: root.active_idx == 3;
                    request-focus => {
                        root.request-activate-item(3);
                    }
                }

                InventoryItem {
                    label: "70 cm";
                    value: root.inv_vals[4];
                    has-focus: root.active_idx == 4;
                    request-focus => {
                        root.request-activate-item(4);
                    }
                }

                InventoryItem {
                    label: "80 cm";
                    value: root.inv_vals[5];
                    has-focus: root.active_idx == 5;
                    request-focus => {
                        root.request-activate-item(5);
                    }
                }

                InventoryItem {
                    label: "90 cm";
                    value: root.inv_vals[6];
                    has-focus: root.active_idx == 6;
                    request-focus => {
                        root.request-activate-item(6);
                    }
                }

                InventoryItem {
                    label: "1 mt";
                    value: root.inv_vals[7];
                    has-focus: root.active_idx == 7;
                    request-focus => {
                        root.request-activate-item(7);
                    }
                }

                // Placeholder - Hidden
                InventoryItem {
                    label: "Hidden";
                    value: root.inv_vals[18];
                    has-focus: false;
                    width: 0px;
                    height: 0px;
                    visible: false;
                }

                SectionHeader {
                    title: "VIGAS Y MADERA";
                }

                LumberItem {
                    label: "2x3\"";
                    value: root.inv_vals[8];
                    has-focus: root.active_idx == 8;
                    selected-length: root.inv_lengths[8];
                    request-focus => {
                        root.request-activate-item(8);
                    }
                    set-length(l) => {
                        root.request-set-length(8, l);
                    }
                }

                LumberItem {
                    label: "2x4\"";
                    value: root.inv_vals[9];
                    has-focus: root.active_idx == 9;
                    selected-length: root.inv_lengths[9];
                    request-focus => {
                        root.request-activate-item(9);
                    }
                    set-length(l) => {
                        root.request-set-length(9, l);
                    }
                }

                LumberItem {
                    label: "2x5\"";
                    value: root.inv_vals[10];
                    has-focus: root.active_idx == 10;
                    selected-length: root.inv_lengths[10];
                    request-focus => {
                        root.request-activate-item(10);
                    }
                    set-length(l) => {
                        root.request-set-length(10, l);
                    }
                }

                LumberItem {
                    label: "2x6\"";
                    value: root.inv_vals[11];
                    has-focus: root.active_idx == 11;
                    selected-length: root.inv_lengths[11];
                    request-focus => {
                        root.request-activate-item(11);
                    }
                    set-length(l) => {
                        root.request-set-length(11, l);
                    }
                }

                LumberItem {
                    label: "2x8\"";
                    value: root.inv_vals[12];
                    has-focus: root.active_idx == 12;
                    selected-length: root.inv_lengths[12];
                    request-focus => {
                        root.request-activate-item(12);
                    }
                    set-length(l) => {
                        root.request-set-length(12, l);
                    }
                }

                LumberItem {
                    label: "2x10\"";
                    value: root.inv_vals[13];
                    has-focus: root.active_idx == 13;
                    selected-length: root.inv_lengths[13];
                    request-focus => {
                        root.request-activate-item(13);
                    }
                    set-length(l) => {
                        root.request-set-length(13, l);
                    }
                }

                SectionHeader {
                    title: "CLAVOS";
                }

                InventoryItem {
                    label: "3\"";
                    value: root.inv_vals[14];
                    has-focus: root.active_idx == 14;
                    request-focus => {
                        root.request-activate-item(14);
                    }
                }

                InventoryItem {
                    label: "3 1/2\"";
                    value: root.inv_vals[15];
                    has-focus: root.active_idx == 15;
                    request-focus => {
                        root.request-activate-item(15);
                    }
                }

                InventoryItem {
                    label: "4\"";
                    value: root.inv_vals[16];
                    has-focus: root.active_idx == 16;
                    request-focus => {
                        root.request-activate-item(16);
                    }
                }

                InventoryItem {
                    label: "Techo 2 1/2\"";
                    value: root.inv_vals[17];
                    has-focus: root.active_idx == 17;
                    request-focus => {
                        root.request-activate-item(17);
                    }
                }

                SectionHeader {
                    title: "CEMENTO";
                }

                InventoryItem {
                    label: "Bolsas";
                    value: root.inv_vals[18];
                    has-focus: root.active_idx == 18;
                    request-focus => {
                        root.request-activate-item(18);
                    }
                }
            }
        }
    }

    NumericKeypad {
        x: 0;
        y: parent.height - self.height;
        z: 50;
        open: root.active_idx != -1;
        custom-key-pressed(k) => {
            root.request-append-digit(k);
        }
        backspace-pressed() => {
            root.request-backspace();
        }
        close-pressed() => {
            root.active_idx = -1;
        }
    }
}
