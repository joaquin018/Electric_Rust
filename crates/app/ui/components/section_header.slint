export component SectionHeader inherits HorizontalLayout {
    in property <string> title;
    spacing: 12px;
    padding-top: 25px;
    padding-bottom: 15px;
    Rectangle {
        width: 4px;
        height: 24px;
        background: #FF9800; // Colors.orange
        border-radius: 2px;
    }

    Text {
        text: title;
        font-size: 18px;
        font-weight: 800;
        color: #FFAB40;
        vertical-alignment: center;
        letter-spacing: 1.5px;
    }
}
