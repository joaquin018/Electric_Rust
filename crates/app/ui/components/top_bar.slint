export component TopBar inherits Rectangle {
    callback copy-pressed();
    callback share-pressed();
    height: 90px;
    background: #000000;
    HorizontalLayout {
        padding-top: 45px; // Status bar padding
        padding-left: 15px;
        padding-right: 15px;
        alignment: space-between;
        Text {
            text: "CONSTRUCT";
            font-size: 24px;
            font-weight: 900;
            color: #ffffff;
            vertical-alignment: center;
            letter-spacing: 2px;
        }

        HorizontalLayout {
            spacing: 25px;
            alignment: end;
            
            // Copy Button (Material 'content_copy')
            Rectangle {
                width: 24px;
                height: 24px;
                TouchArea {
                    clicked => {
                        root.copy-pressed();
                    }
                }

                Path {
                    width: 100%;
                    height: 100%;
                    fill: #ff9d00;
                    stroke-width: 0;
                    commands: "M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z";
                }
            }

            // Share Button (Material 'share')
            Rectangle {
                width: 24px;
                height: 24px;
                TouchArea {
                    clicked => {
                        root.share-pressed();
                    }
                }

                Path {
                    width: 100%;
                    height: 100%;
                    fill: #ff9d00;
                    stroke-width: 0;
                    commands: "M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z";
                }
            }
        }
    }
}
