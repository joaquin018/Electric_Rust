export component IconButton inherits Rectangle {
    in property <string> icon-path;
    callback clicked;
    width: 48px;
    height: 48px;
    background: transparent;
    clip: true;
    border-radius: 24px;

    // Background Flash Effect (Responsive Feedback)
    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: root.border-radius;
        background: transparent;
        
        // Use states for asymmetric animation (Instant In, Slow Out)
        states [
            pressed when touch.pressed: {
                background: #FFFFFF22; // Visible highlight (White 13%)
                in {
                    animate background { duration: 0ms; }
                }
                out {
                    animate background { duration: 50ms; }
                }
            }
        ]
    }

    in property <brush> icon-fill: #FFAB40;
    // Icon
    Path {
        width: 24px;
        height: 24px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        commands: root.icon-path;
        fill: root.icon-fill;
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            root.clicked();
        }
    }
}

export component TopBar inherits Rectangle {
    callback selective-share-pressed();
    callback full-share-pressed();
    height: 90px;
    background: transparent;
    HorizontalLayout {
        padding-top: 45px;
        padding-left: 20px;
        padding-right: 5px;
        spacing: 5px;
        alignment: start;

        Text {
            text: "CONSTRUCT";
            font-size: 24px;
            font-weight: 900;
            color: #ffffff;
            vertical-alignment: center;
            letter-spacing: 2px;
        }

        // Flex Spacer to push actions to the right
        Rectangle {
            horizontal-stretch: 1;
        }

        HorizontalLayout {
            spacing: 5px;
            alignment: end;
            
            // Selective Share Button (Celeste/Light Blue)
            IconButton {
                icon-path: "M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z";
                icon-fill: #03A9F4; // Celeste / Light Blue
                clicked => {
                    root.selective-share-pressed();
                }
            }

            // Full Share Button (Original Orange)
            IconButton {
                icon-path: "M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z";
                clicked => {
                    root.full-share-pressed();
                }
            }
        }
    }
}
