export component IconButton inherits Rectangle {
    in property <string> icon-path;
    callback clicked;
    width: 48px;
    height: 48px;
    background: transparent;
    clip: true;
    border-radius: 24px;

    // Background Flash Effect (Responsive Feedback)
    Rectangle {
        width: 100%;
        height: 100%;
        border-radius: root.border-radius;
        background: transparent;
        
        // Use states for asymmetric animation (Instant In, Slow Out)
        states [
            pressed when touch.pressed: {
                background: #FFFFFF22; // Visible highlight (White 13%)
                in {
                    animate background { duration: 0ms; }
                }
                out {
                    animate background { duration: 50ms; }
                }
            }
        ]
    }

    // Icon
    Path {
        width: 24px;
        height: 24px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        commands: root.icon-path;
        fill: #FFAB40;
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            root.clicked();
        }
    }
}

component MenuButton inherits Rectangle {
    callback clicked;
    width: 48px;
    height: 48px;
    background: transparent;
    Path {
        width: 24px;
        height: 24px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        commands: "M3 18h18v-2H3v2zm0-5h18v-2H3v2zm0-7v2h18V6H3z";
        fill: #FFFFFF;
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        clicked => {
            root.clicked();
        }
    }
}

export component TopBar inherits Rectangle {
    callback copy-pressed();
    callback share-pressed();
    callback menu-pressed();
    height: 90px;
    background: transparent;
    HorizontalLayout {
        padding-top: 45px;
        padding-left: 15px;
        padding-right: 5px;
        spacing: 5px;
        alignment: start;

        // Optimized Menu Button
        MenuButton {
            clicked => {
                root.menu-pressed();
            }
        }

        Text {
            text: "CONSTRUCT";
            font-size: 24px;
            font-weight: 900;
            color: #ffffff;
            vertical-alignment: center;
            letter-spacing: 2px;
        }

        // Flex Spacer to push actions to the right
        Rectangle {
            horizontal-stretch: 1;
        }

        HorizontalLayout {
            spacing: 5px;
            alignment: end;
            
            // Copy Button (Material 'content_copy')
            IconButton {
                icon-path: "M16 1H4c-1.1 0-2 .9-2 2v14h2V3h12V1zm3 4H8c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h11c1.1 0 2-.9 2-2V7c0-1.1-.9-2-2-2zm0 16H8V7h11v14z";
                clicked => {
                    root.copy-pressed();
                }
            }

            // Share Button (Material 'share')
            IconButton {
                icon-path: "M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z";
                clicked => {
                    root.share-pressed();
                }
            }
        }
    }
}
