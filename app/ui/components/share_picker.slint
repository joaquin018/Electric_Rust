import { Button, VerticalBox } from "std-widgets.slint";
import { SelectionItem } from "selection_item.slint";

export component SharePicker inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <bool> share-empalme: false;
    in-out property <bool> share-interior: false;
    in-out property <bool> share-cables: false;
    callback back-pressed();
    // Maintain 5 bools for compatibility with the Rust backend callback for now, 
    // mapping the 3 new ones and leaving 2 as false.
    callback share-confirmed(bool, bool, bool, bool, bool);

    // Backdrop
    Rectangle {
        background: #000000;
        opacity: root.open ? 0.7 : 0;
        visible: self.opacity > 0;
        animate opacity { duration: 300ms; }
        TouchArea {
            clicked => {
                root.back-pressed();
            }
        }
    }

    // Modal Content
    Rectangle {
        width: 320px;
        height: 400px; // Reduced height
        background: #1E1E1E;
        border-radius: 24px;
        border-width: 1px;
        border-color: #444444;
        drop-shadow-blur: 30px;
        drop-shadow-color: #000000CC;
        x: (parent.width - self.width) / 2;
        y: root.open ? (parent.height - self.height) / 2 : parent.height + 100px;
        animate y {
            duration: 400ms;
            easing: cubic-bezier(0.16, 1, 0.3, 1);
        }
        TouchArea { }

        VerticalLayout {
            padding: 24px;
            spacing: 20px;
            alignment: space-between;
            VerticalLayout {
                spacing: 20px;
                Text {
                    text: "SELECCIONAR SECCIONES";
                    color: white;
                    font-size: 16px;
                    font-weight: 900;
                    letter-spacing: 2px;
                    horizontal-alignment: center;
                }

                // Selection List
                VerticalLayout {
                    spacing: 12px;
                    SelectionItem {
                        text: "EMPALME";
                        selected: root.share-empalme;
                        clicked => {
                            root.share-empalme = !root.share-empalme;
                        }
                    }

                    SelectionItem {
                        text: "INTERIOR";
                        selected: root.share-interior;
                        clicked => {
                            root.share-interior = !root.share-interior;
                        }
                    }

                    SelectionItem {
                        text: "CABLES";
                        selected: root.share-cables;
                        clicked => {
                            root.share-cables = !root.share-cables;
                        }
                    }
                }
            }

            // Share Button
            Rectangle {
                height: 56px;
                background: share-touch.pressed ? #B3E5FC : #81D4FA;
                border-radius: 28px;
                animate background { duration: 100ms; }
                share-touch := TouchArea {
                    clicked => {
                        root.share-confirmed(
                            root.share-empalme, 
                            false, // door
                            root.share-cables, // roof
                            false, // insulation
                            root.share-interior);
                        root.open = false;
                    }
                }

                Text {
                    text: "COMPARTIR";
                    color: #121212;
                    font-weight: 900;
                    font-size: 15px;
                    letter-spacing: 1.5px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
