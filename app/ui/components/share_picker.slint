import { Button, VerticalBox } from "std-widgets.slint";
import { SelectionItem } from "selection_item.slint";

export component SharePicker inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <bool> share-base: false;
    in-out property <bool> share-door: false;
    in-out property <bool> share-roof: false;
    in-out property <bool> share-insulation: false;
    in-out property <bool> share-interior: false;
    callback back-pressed();
    callback share-confirmed(bool, bool, bool, bool, bool);

    // Backdrop
    Rectangle {
        background: #000000;
        opacity: root.open ? 0.7 : 0;
        visible: self.opacity > 0;
        animate opacity { duration: 300ms; }
        TouchArea {
            clicked => {
                root.back-pressed();
            }
        }
    }

    // Modal Content
    Rectangle {
        width: 300px;
        height: 480px;
        background: #1E1E1E;
        border-radius: 20px;
        border-width: 1px;
        border-color: #333333;
        drop-shadow-blur: 20px;
        drop-shadow-color: #000000AA;
        cache-rendering-hint: true;
        x: (parent.width - self.width) / 2;
        y: root.open ? (parent.height - self.height) / 2 : parent.height;
        animate y {
            duration: 350ms;
            easing: cubic-bezier(0.05, 0.7, 0.1, 1.0);
        }
        TouchArea {
            // Blocks clicks from reaching the backdrop
        }

        VerticalLayout {
            padding: 24px;
            spacing: 20px;
            alignment: start;
            Text {
                text: "SELECCIONAR SECCIONES";
                color: white;
                font-size: 16px;
                font-weight: 900;
                letter-spacing: 2.5px;
                horizontal-alignment: center;
            }

            // Selection List
            VerticalLayout {
                spacing: 12px;
                
                // Item: Base
                SelectionItem {
                    text: "BASE";
                    selected: root.share-base;
                    clicked => {
                        root.share-base = !root.share-base;
                    }
                }

                // Item: Puerta
                SelectionItem {
                    text: "PUERTA";
                    selected: root.share-door;
                    clicked => {
                        root.share-door = !root.share-door;
                    }
                }

                // Item: Tingle y Techo
                SelectionItem {
                    text: "TINGLE Y TECHO";
                    selected: root.share-roof;
                    clicked => {
                        root.share-roof = !root.share-roof;
                    }
                }

                // Item: Aislacion
                SelectionItem {
                    text: "AISLACIÓN";
                    selected: root.share-insulation;
                    clicked => {
                        root.share-insulation = !root.share-insulation;
                    }
                }

                // Item: Interior
                SelectionItem {
                    text: "INTERIOR";
                    selected: root.share-interior;
                    clicked => {
                        root.share-interior = !root.share-interior;
                    }
                }
            }

            Rectangle {
                vertical-stretch: 1;
            } // Spacer

            // Button Wrapper for centering
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    // Share Button (Selective)
                    Rectangle {
                        width: 200px;
                        height: 50px;
                        background: #FFAB40;
                        border-radius: 25px; // Fully roundedpill
                        drop-shadow-blur: 8px;
                        drop-shadow-color: #00000044;
                        TouchArea {
                            clicked => {
                                root.share-confirmed(root.share-base, root.share-door, root.share-roof, root.share-insulation, root.share-interior);
                                root.open = false;
                            }
                        }

                        Text {
                            text: "COMPARTIR";
                            color: #1E1E1E; // Contrast text
                            font-weight: 900;
                            font-size: 14px;
                            letter-spacing: 1px;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
