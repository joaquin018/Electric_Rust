import { Button, VerticalBox } from "std-widgets.slint";
import { SelectionItem } from "selection_item.slint";

export component SharePicker inherits Rectangle {
    in-out property <bool> open: false;
    in-out property <bool> share-base: true;
    in-out property <bool> share-door: true;
    in-out property <bool> share-roof: true;
    in-out property <bool> share-insulation: true;
    in-out property <bool> share-interior: true;
    callback back-pressed();
    callback share-confirmed(bool, bool, bool, bool, bool);

    // Backdrop
    Rectangle {
        background: #000000;
        opacity: root.open ? 0.7 : 0;
        visible: self.opacity > 0;
        animate opacity { duration: 300ms; }
        TouchArea {
            clicked => {
                root.back-pressed();
            }
        }
    }

    // Modal Content
    Rectangle {
        width: 320px;
        height: 520px;
        background: #1E1E1E;
        border-radius: 24px;
        border-width: 1px;
        border-color: #444444;
        drop-shadow-blur: 30px;
        drop-shadow-color: #000000CC;
        x: (parent.width - self.width) / 2;
        y: root.open ? (parent.height - self.height) / 2 : parent.height + 100px;
        animate y {
            duration: 400ms;
            easing: cubic-bezier(0.16, 1, 0.3, 1);
        }
        VerticalLayout {
            padding: 24px;
            spacing: 20px;
            alignment: space-between;
            VerticalLayout {
                spacing: 20px;
                Text {
                    text: "SELECCIONAR SECCIONES";
                    color: white;
                    font-size: 16px;
                    font-weight: 900;
                    letter-spacing: 2px;
                    horizontal-alignment: center;
                }

                // Selection List
                VerticalLayout {
                    spacing: 12px;
                    SelectionItem {
                        text: "BASE";
                        selected: root.share-base;
                        clicked => {
                            root.share-base = !root.share-base;
                        }
                    }

                    SelectionItem {
                        text: "PUERTA";
                        selected: root.share-door;
                        clicked => {
                            root.share-door = !root.share-door;
                        }
                    }

                    SelectionItem {
                        text: "TINGLE Y TECHO";
                        selected: root.share-roof;
                        clicked => {
                            root.share-roof = !root.share-roof;
                        }
                    }

                    SelectionItem {
                        text: "AISLACIÓN";
                        selected: root.share-insulation;
                        clicked => {
                            root.share-insulation = !root.share-insulation;
                        }
                    }

                    SelectionItem {
                        text: "INTERIOR";
                        selected: root.share-interior;
                        clicked => {
                            root.share-interior = !root.share-interior;
                        }
                    }
                }
            }

            // Share Button
            Rectangle {
                height: 56px;
                background: share-touch.pressed ? #FFB74D : #FFAB40;
                border-radius: 28px;
                animate background { duration: 100ms; }
                share-touch := TouchArea {
                    clicked => {
                        root.share-confirmed(
                            root.share-base, 
                            root.share-door, 
                            root.share-roof, 
                            root.share-insulation, 
                            root.share-interior);
                        root.open = false;
                    }
                }

                Text {
                    text: "COMPARTIR";
                    color: #121212;
                    font-weight: 900;
                    font-size: 15px;
                    letter-spacing: 1.5px;
                    vertical-alignment: center;
                    horizontal-alignment: center;
                }
            }
        }
    }
}
