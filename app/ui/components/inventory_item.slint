import { Button } from "std-widgets.slint";
import { EditableValueDisplay } from "editable_value_display.slint";

export component InventoryItem inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <bool> has-focus: false;
    callback request-focus();

    // MaterialCard styling (Flutter replica)
    height: 80px;
    background: #1E1E1E;
    border-radius: 16px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.05);
    
    // Shadow
    drop-shadow-color: rgba(0, 0, 0, 0.2);
    drop-shadow-blur: 10px;
    drop-shadow-offset-y: 4px;
    HorizontalLayout {
        padding-left: 16px;
        padding-right: 16px;
        alignment: space-between;
        
        // Material Label
        Text {
            text: label;
            color: #ffffff;
            font-size: 16px;
            font-weight: 500;
            vertical-alignment: center;
        }

        // Input Field Container Wrapper for centering
        VerticalLayout {
            alignment: center;
            // Reusable Input Field Container
            EditableValueDisplay {
                value: root.value;
                has-focus: root.has-focus;
                clicked => {
                    root.request-focus();
                }
            }
        }
    }
}
