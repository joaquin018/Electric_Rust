import { VerticalBox } from "std-widgets.slint";

export component BottomBar inherits Rectangle {
    // Properties
    in-out property <int> current-screen: 0;
    in property <length> bottom-padding: 0px;

    // Styling
    min-height: 60px + root.bottom-padding;
    background: #1E1E1E;
    border-width: 1px;
    border-color: #FFFFFF10;
    
    // Callback for screen changes (Required for the Rust logic)
    callback changed();

    HorizontalLayout {
        padding-bottom: root.bottom-padding;
        spacing: 0px;
        
        // Button 1: Empalme (Base Logic)
        Rectangle {
            width: root.width / 3;
            background: root.current-screen == 0 ? #FFFFFF10 : transparent;
            TouchArea {
                clicked => {
                    root.current-screen = 0;
                    root.changed();
                }
            }

            VerticalLayout {
                alignment: center;
                padding-top: 8px;
                padding-bottom: 8px;
                Text {
                    text: "Empalme";
                    color: root.current-screen == 0 ? #81D4FA : #FFFFFF88;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
        
        // Button 2: Interior
        Rectangle {
            width: root.width / 3;
            background: root.current-screen == 1 ? #FFFFFF10 : transparent;
            TouchArea {
                clicked => {
                    root.current-screen = 1;
                    root.changed();
                }
            }

            VerticalLayout {
                alignment: center;
                padding-top: 8px;
                padding-bottom: 8px;
                Text {
                    text: "Interior";
                    color: root.current-screen == 1 ? #81D4FA : #FFFFFF88;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
        
        // Button 3: Cables
        Rectangle {
            width: root.width / 3;
            background: root.current-screen == 2 ? #FFFFFF10 : transparent;
            TouchArea {
                clicked => {
                    root.current-screen = 2;
                    root.changed();
                }
            }

            VerticalLayout {
                alignment: center;
                padding-top: 8px;
                padding-bottom: 8px;
                Text {
                    text: "Cables";
                    color: root.current-screen == 2 ? #81D4FA : #FFFFFF88;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
    }
}
