import { VerticalBox } from "std-widgets.slint";

export component BottomBar inherits Rectangle {
    // Properties
    in-out property <int> current-screen: 0;
    in property <length> bottom-padding: 0px;

    // Styling
    height: 60px + root.bottom-padding;
    background: #1E1E1E;
    border-width: 1px;
    border-color: #FFFFFF10;
    // Layout Manual para precisión absoluta y evitar bugs de flexbox
    // Base Button
    Rectangle {
        x: 0;
        width: 20%;
        height: parent.height - root.bottom-padding;
        y: 0;
        background: root.current-screen == 0 ? #FFFFFF10 : transparent;
        TouchArea {
            clicked => {
                root.current-screen = 0;
            }
        }

        Text {
            width: 100%;
            height: 100%;
            text: "Base";
            color: root.current-screen == 0 ? #FFAB40 : #FFFFFF88;
            font-size: 14px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    
    // Door Button
    Rectangle {
        x: parent.width * 0.20;
        width: 20%;
        height: parent.height - root.bottom-padding;
        y: 0;
        background: root.current-screen == 1 ? #FFFFFF10 : transparent;
        TouchArea {
            clicked => {
                root.current-screen = 1;
            }
        }

        Text {
            width: 100%;
            height: 100%;
            text: "Puerta";
            color: root.current-screen == 1 ? #FFAB40 : #FFFFFF88;
            font-size: 14px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    
    // Roof Button
    Rectangle {
        x: parent.width * 0.40;
        width: 20%;
        height: parent.height - root.bottom-padding;
        y: 0;
        background: root.current-screen == 2 ? #FFFFFF10 : transparent;
        TouchArea {
            clicked => {
                root.current-screen = 2;
            }
        }

        Text {
            width: 100%;
            height: 100%;
            text: "Tingle y techo";
            color: root.current-screen == 2 ? #FFAB40 : #FFFFFF88;
            font-size: 14px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            wrap: word-wrap;
        }
    }
    
    // Insulation Button
    Rectangle {
        x: parent.width * 0.60;
        width: 20%;
        height: parent.height - root.bottom-padding;
        y: 0;
        background: root.current-screen == 3 ? #FFFFFF10 : transparent;
        TouchArea {
            clicked => {
                root.current-screen = 3;
            }
        }

        Text {
            width: 100%;
            height: 100%;
            text: "Aislación";
            color: root.current-screen == 3 ? #FFAB40 : #FFFFFF88;
            font-size: 14px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
    
    // Interior Button
    Rectangle {
        x: parent.width * 0.80;
        width: 20%;
        height: parent.height - root.bottom-padding;
        y: 0;
        background: root.current-screen == 4 ? #FFFFFF10 : transparent;
        TouchArea {
            clicked => {
                root.current-screen = 4;
            }
        }

        Text {
            width: 100%;
            height: 100%;
            text: "Interior";
            color: root.current-screen == 4 ? #FFAB40 : #FFFFFF88;
            font-size: 14px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }
}
