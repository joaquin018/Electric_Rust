import { VerticalBox } from "std-widgets.slint";

export component BottomBar inherits Rectangle {
    // Properties
    in-out property <int> current-screen: 0;
    in property <length> bottom-padding: 0px;

    // Styling
    // Use min-height so the bar can grow if labels wrap.
    // Fixed height was causing issues with long text.
    min-height: 60px + root.bottom-padding;
    background: #1E1E1E;
    border-width: 1px;
    border-color: #FFFFFF10;
    
    // Callback for screen changes (Required for the Rust logic)
    callback changed();

    // Use a HorizontalLayout to ensure all buttons share the SAME height
    // and can push the parent height up if they wrap.
    HorizontalLayout {
        padding-bottom: root.bottom-padding;
        spacing: 0px;
        
        // Button 1: Base
        Rectangle {
            // Force strict 20% width
            width: root.width / 5;
            background: root.current-screen == 0 ? #FFFFFF10 : transparent;
            TouchArea {
                clicked => {
                    root.current-screen = 0;
                    root.changed();
                }
            }

            VerticalLayout {
                alignment: center;
                padding-top: 8px;
                padding-bottom: 8px;
                Text {
                    text: "Base";
                    color: root.current-screen == 0 ? #81D4FA : #FFFFFF88;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
        
        // Button 2: Puerta
        Rectangle {
            width: root.width / 5;
            background: root.current-screen == 1 ? #FFFFFF10 : transparent;
            TouchArea {
                clicked => {
                    root.current-screen = 1;
                    root.changed();
                }
            }

            VerticalLayout {
                alignment: center;
                padding-top: 8px;
                padding-bottom: 8px;
                Text {
                    text: "Puerta";
                    color: root.current-screen == 1 ? #81D4FA : #FFFFFF88;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
        
        // Button 3: Tingle y techo (Long text example)
        Rectangle {
            width: root.width / 5;
            background: root.current-screen == 2 ? #FFFFFF10 : transparent;
            TouchArea {
                clicked => {
                    root.current-screen = 2;
                    root.changed();
                }
            }

            VerticalLayout {
                alignment: center;
                padding-top: 8px;
                padding-bottom: 8px;
                padding-left: 2px;
                padding-right: 2px;
                Text {
                    text: "Tingle y techo";
                    color: root.current-screen == 2 ? #81D4FA : #FFFFFF88;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
        
        // Button 4: Aislación
        Rectangle {
            width: root.width / 5;
            background: root.current-screen == 3 ? #FFFFFF10 : transparent;
            TouchArea {
                clicked => {
                    root.current-screen = 3;
                    root.changed();
                }
            }

            VerticalLayout {
                alignment: center;
                padding-top: 8px;
                padding-bottom: 8px;
                Text {
                    text: "Aislación";
                    color: root.current-screen == 3 ? #81D4FA : #FFFFFF88;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
        
        // Button 5: Interior
        Rectangle {
            width: root.width / 5;
            background: root.current-screen == 4 ? #FFFFFF10 : transparent;
            TouchArea {
                clicked => {
                    root.current-screen = 4;
                    root.changed();
                }
            }

            VerticalLayout {
                alignment: center;
                padding-top: 8px;
                padding-bottom: 8px;
                Text {
                    text: "Interior";
                    color: root.current-screen == 4 ? #81D4FA : #FFFFFF88;
                    font-size: 13px;
                    font-weight: 700;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }
    }
}
