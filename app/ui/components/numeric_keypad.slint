import { Button, VerticalBox } from "std-widgets.slint";
import { KeyButton } from "key_button.slint";

export component NumericKeypad inherits Rectangle {
    in property <bool> open: false;
    in property <length> bottom-padding: 0px;
    callback custom-key-pressed(string);
    callback backspace-pressed();
    callback close-pressed();
    width: 100%;
    height: 100%;

    // Solo visible cuando está abierto o animándose
    visible: root.open || panel.y < root.height;

    // Panel deslizante compacto
    panel := Rectangle {
        background: #1e1e1e;
        border-top-left-radius: 20px;
        border-top-right-radius: 20px;
        height: 270px + root.bottom-padding;
        width: 100%;
        y: root.open ? parent.height - self.height : parent.height;
        animate y {
            duration: 220ms;
            easing: cubic-bezier(0.05, 0.7, 0.1, 1.0);
        }

        // Gesture detection
        TouchArea {
            width: 100%;
            height: 100%;
            moved => {
                if (self.pressed && self.mouse-y > 40px) {
                    root.close-pressed();
                }
            }
        }

        VerticalLayout {
            padding: 10px;
            padding-bottom: 15px + root.bottom-padding;
            padding-top: 12px;
            spacing: 8px;
            
            // Handle visual indicator
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 40px;
                    height: 4px;
                    background: #FFFFFF33;
                    border-radius: 2px;
                }
            }

            GridLayout {
                spacing: 8px;
                Row {
                    KeyButton {
                        text: "1";
                        clicked => {
                            root.custom-key-pressed("1");
                        }
                    }

                    KeyButton {
                        text: "2";
                        clicked => {
                            root.custom-key-pressed("2");
                        }
                    }

                    KeyButton {
                        text: "3";
                        clicked => {
                            root.custom-key-pressed("3");
                        }
                    }
                }

                Row {
                    KeyButton {
                        text: "4";
                        clicked => {
                            root.custom-key-pressed("4");
                        }
                    }

                    KeyButton {
                        text: "5";
                        clicked => {
                            root.custom-key-pressed("5");
                        }
                    }

                    KeyButton {
                        text: "6";
                        clicked => {
                            root.custom-key-pressed("6");
                        }
                    }
                }

                Row {
                    KeyButton {
                        text: "7";
                        clicked => {
                            root.custom-key-pressed("7");
                        }
                    }

                    KeyButton {
                        text: "8";
                        clicked => {
                            root.custom-key-pressed("8");
                        }
                    }

                    KeyButton {
                        text: "9";
                        clicked => {
                            root.custom-key-pressed("9");
                        }
                    }
                }

                Row {
                    KeyButton {
                        text: ".";
                        clicked => {
                            root.custom-key-pressed(".");
                        }
                    }

                    KeyButton {
                        text: "0";
                        clicked => {
                            root.custom-key-pressed("0");
                        }
                    }

                    KeyButton {
                        icon-path: "M22 3H7c-.69 0-1.23.35-1.59.88L0 12l5.41 8.11c.36.53.9.89 1.59.89h15c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-3 12.59L17.59 17 14 13.41 10.41 17 9 15.59 12.59 12 9 8.41 10.41 7 14 10.59 17.59 7 19 8.41 15.41 12 19 15.59z";
                        special: true;
                        clicked => {
                            root.backspace-pressed();
                        }
                    }
                }
            }
        }
    }
}
