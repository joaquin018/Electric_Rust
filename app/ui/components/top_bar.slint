import { IconButton } from "icon_button.slint";

export component TopBar inherits Rectangle {
    in property <string> title: "ELECTRIC";
    callback selective-share-pressed();
    callback trash-pressed();
    height: 90px;
    background: transparent;
    HorizontalLayout {
        padding-top: 45px;
        padding-left: 20px;
        padding-right: 0px;
        spacing: 5px;
        // alignment: start; // Removed to allow spacer to push content to edges
        Text {
            text: root.title;
            font-size: 22px;
            font-weight: 900;
            color: #ffffff;
            vertical-alignment: center;
            letter-spacing: 2px;
            overflow: elide;
            horizontal-stretch: 1;
        }

        HorizontalLayout {
            spacing: 5px;
            alignment: end;
            
            // Share Button (Now Orange)
            IconButton {
                icon-path: "M18 16.08c-.76 0-1.44.3-1.96.77L8.91 12.7c.05-.23.09-.46.09-.7s-.04-.47-.09-.7l7.05-4.11c.54.5 1.25.81 2.04.81 1.66 0 3-1.34 3-3s-1.34-3-3-3-3 1.34-3 3c0 .24.04.47.09.7L8.04 9.81C7.5 9.31 6.79 9 6 9c-1.66 0-3 1.34-3 3s1.34 3 3 3c.79 0 1.5-.31 2.04-.81l7.12 4.16c-.05.21-.08.43-.08.65 0 1.61 1.31 2.92 2.92 2.92 1.61 0 2.92-1.31 2.92-2.92s-1.31-2.92-2.92-2.92z";
                icon-fill: #81D4FA;
                clicked => {
                    root.selective-share-pressed();
                }
            }

            // Trash Button (Future use)
            IconButton {
                icon-path: "M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z";
                clicked => {
                    root.trash-pressed();
                }
            }
        }
    }
}
