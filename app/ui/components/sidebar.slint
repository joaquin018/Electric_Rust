

export component SideBar inherits Rectangle {
    // Properties kept for API compatibility with main.slint (though unused internally now)
    in-out property <bool> open: false;
    callback close-requested();
    callback open-requested();
    callback navigate-to(int);
    in-out property <int> current-screen: 0;
    in property <length> bottom-padding: 0px;

    // Dimensions
    width: 20px; // Only the catch area
    height: 100%;
    x: 0;
    background: transparent;

    // Edge Swipe Detector (Trigger)
    TouchArea {
        width: 100%;
        height: 100%;
        moved => {
            // Sensitivity
            if (self.pressed && self.mouse-x > 50px) {
                root.open-requested();
            }
        }
    }
}
