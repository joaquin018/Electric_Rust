import { Button } from "std-widgets.slint";
import { LengthChip } from "length_chip.slint";
import { EditableValueDisplay } from "editable_value_display.slint";

export component LumberItem inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <bool> has-focus: false;
    in property <int> selected-length: 0; // 0=3.2, 1=4, 2=5, 3=6
    callback request-focus();
    callback set-length(int);

    // MaterialCard styling (Taller)
    height: 130px; // Increased to fit buttons
    background: #1E1E1E;
    border-radius: 16px;
    border-width: 1px;
    border-color: rgba(255, 255, 255, 0.05);
    
    // Shadow
    drop-shadow-color: rgba(0, 0, 0, 0.2);
    drop-shadow-blur: 10px;
    drop-shadow-offset-y: 4px;
    VerticalLayout {
        padding: 16px;
        spacing: 12px;

        // Top Row: Label vs Value (Reusable Layout)
        HorizontalLayout {
            alignment: space-between;
            
            // Material Label
            Text {
                text: label;
                color: #ffffff;
                font-size: 16px;
                font-weight: 500;
                vertical-alignment: center;
            }

            // Input Field Container Wrapper
            VerticalLayout {
                alignment: center;
                EditableValueDisplay {
                    value: root.value;
                    has-focus: root.has-focus;
                    clicked => {
                        root.request-focus();
                    }
                }
            }
        }

        // Bottom Row: Length Chips
        HorizontalLayout {
            alignment: space-around; // Better spacing for loop
            spacing: 8px;
            for len[i] in ["3.2m", "4m", "5m", "6m"]: LengthChip {
                text: len;
                selected: root.selected-length == i;
                clicked => {
                    root.set-length(i);
                }
            }
        }
    }
}
