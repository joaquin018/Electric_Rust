import {
    Button,
    VerticalBox,
    ScrollView,
    StandardTableView,
} from "std-widgets.slint";

export component ProjectListScreen inherits Rectangle {
    in property <[string]> project-names;
    callback create-project(string);
    callback delete-project(int);
    callback open-project(int);
    callback rename-project(int, string);
    in property <length> bottom-padding: 0px;

    // New project name buffer
    property <string> new-project-name: "";
    // Modals
    in-out property <bool> show-create-dialog: false;
    in-out property <bool> show-delete-dialog: false;

    // Rename
    property <int> rename-index: -1;
    property <string> rename-buffer: "";
    property <bool> show-rename-dialog: false;

    // Delete Confirmation
    property <int> delete-target-index: -1;
    property <string> delete-target-name: "";

    // Background
    background: #121212;
    focus-stealer := FocusScope {
        width: 0px;
        height: 0px;
    }

    VerticalLayout {
        padding-top: 60px;
        padding-left: 16px;
        padding-right: 16px;
        padding-bottom: 24px + root.bottom-padding;
        spacing: 24px;
        alignment: start;

        // Header
        Text {
            text: "PROYECTOS";
            font-size: 28px;
            font-weight: 900;
            color: #FFFFFF;
            letter-spacing: 2px;
        }

        // Project List
        Flickable {
            viewport-height: content.preferred-height;
            content := VerticalBox {
                spacing: 12px;
                alignment: start;
                for name[i] in root.project-names: Rectangle {
                    height: 96px;
                    border-radius: 16px;
                    background: #2C2C2C;
                    border-width: 1px;
                    border-color: #FFFFFF10;
                    HorizontalLayout {
                        padding-left: 20px;
                        padding-right: 20px;
                        spacing: 20px;
                        alignment: space-between;
                        
                        // Icon + Text
                        HorizontalLayout {
                            horizontal-stretch: 1;
                            spacing: 16px;
                            Rectangle {
                                width: 40px;
                                height: 40px;
                                border-radius: 10px;
                                background: #81D4FA20;
                                y: (parent.height - self.height) / 2;
                                Path {
                                    width: 24px;
                                    height: 24px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    commands: "M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z";
                                    fill: #81D4FA;
                                }
                            }

                            Text {
                                text: name;
                                color: #FFFFFF;
                                font-size: 18px;
                                font-weight: 600;
                                vertical-alignment: center;
                                overflow: elide;
                            }
                        }

                        // Actions
                        HorizontalLayout {
                            spacing: 12px;
                           // Delete Button
                           Rectangle {
                                width: 40px;
                                height: 40px;
                                border-radius: 20px;
                                background: #FF404020;
                                y: (parent.height - self.height) / 2;
                                Path {
                                    width: 20px;
                                    height: 20px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    commands: "M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z";
                                    fill: #FF4040;
                                }

                                TouchArea {
                                    clicked => {
                                        root.delete-target-index = i;
                                        root.delete-target-name = name;
                                        root.show-delete-dialog = true;
                                    }
                                }
                            }
                        }
                    }

                    // Open Click
                    TouchArea {
                        z: -1; // Below actions
                         clicked => {
                            root.open-project(i);
                        }
                    }
                }
            }
        }
    }

    // Floating Action Button
    Rectangle {
        x: parent.width - 80px;
        y: parent.height - 140px;
        width: 56px;
        height: 56px;
        border-radius: 28px;
        background: #81D4FA;
        
        // Shadow
        drop-shadow-color: #00000066;
        drop-shadow-blur: 8px;
        drop-shadow-offset-y: 4px;
        Path {
            width: 24px;
            height: 24px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            commands: "M19 13h-6v6h-2v-6H5v-2h6V5h2v6h6v2z";
            fill: #000000;
        }

        TouchArea {
            clicked => {
                root.show-create-dialog = true;
                root.new-project-name = ""; // Start with empty buffer for placeholder
            }
        }
    }

    // Modal Dialog (Create)
    if root.show-create-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: #000000AA;
        
        // Bloquear toques al fondo
        TouchArea { }

        Rectangle {
            width: 330px;
            // Vinculamos la altura al contenido para que no se estire
            height: create-layout.preferred-height;
            background: #1E1E1E;
            border-radius: 24px;
            border-width: 1px;
            border-color: #333333;
            drop-shadow-blur: 30px;
            drop-shadow-color: #000000;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            create-layout := VerticalLayout {
                padding: 28px;
                spacing: 24px;
                alignment: center;
                Text {
                    text: "Crear Nuevo Proyecto";
                    font-size: 20px;
                    font-weight: 800;
                    color: #FFFFFF;
                    horizontal-alignment: center;
                }

                // Caja de entrada
                Rectangle {
                    height: 56px;
                    background: #252525;
                    border-radius: 12px;
                    border-width: 1px;
                    border-color: #FFFFFF10;
                    
                    // Placeholder Overlay
                    if root.new-project-name == "": Text {
                        x: 16px;
                        text: "Nuevo Proyecto";
                        color: #AAAAAA;
                        font-size: 16px;
                        font-weight: 500;
                        vertical-alignment: center;
                    }
                    HorizontalLayout {
                        padding-left: 16px;
                        padding-right: 16px;
                        TextInput {
                            text <=> root.new-project-name;
                            color: #FFFFFF;
                            font-size: 16px;
                            font-weight: 500;
                            vertical-alignment: center;
                        }
                    }
                }

                // Botones de acción
                HorizontalLayout {
                    spacing: 12px;
                    
                    // Cancelar
                    Rectangle {
                        height: 50px;
                        horizontal-stretch: 1;
                        border-radius: 25px;
                        background: #333333;
                        Text {
                            text: "Cancelar";
                            color: #FFFFFF;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                focus-stealer.focus();
                                root.show-create-dialog = false;
                            }
                        }
                    }

                    // Crear
                    Rectangle {
                        height: 50px;
                        horizontal-stretch: 1;
                        border-radius: 25px;
                        background: #81D4FA;
                        Text {
                            text: "Crear";
                            color: #121212;
                            font-weight: 800;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                focus-stealer.focus();
                                // Use placeholder value as default if empty
                                root.create-project(root.new-project-name == "" ? "Nuevo Proyecto" : root.new-project-name);
                                root.show-create-dialog = false;
                            }
                        }
                    }
                }
            }
        }
    }

    // Modal Dialog (Delete Confirmation)
    if root.show-delete-dialog: Rectangle {
        width: 100%;
        height: 100%;
        background: #000000AA;
        TouchArea { } // Block clicks

        Rectangle {
            width: 320px;
            height: del-layout.preferred-height;
            background: #1E1E1E;
            border-radius: 24px;
            border-width: 1px;
            border-color: #FF404033;
            drop-shadow-blur: 30px;
            drop-shadow-color: #000000;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            del-layout := VerticalLayout {
                padding: 28px;
                spacing: 24px;
                
                // Warning Icon Container
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 60px;
                        height: 60px;
                        background: #FF404015;
                        border-radius: 30px;
                        Path {
                            width: 30px;
                            height: 30px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            viewbox-width: 24;
                            viewbox-height: 24;
                            commands: "M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z";
                            fill: #FF4040;
                        }
                    }
                }

                VerticalLayout {
                    spacing: 8px;
                    Text {
                        text: "¿Eliminar Proyecto?";
                        font-size: 20px;
                        font-weight: 800;
                        color: #FFFFFF;
                        horizontal-alignment: center;
                    }

                    Text {
                        text: "Se eliminará permanentemente:\n\"" + root.delete-target-name + "\"";
                        font-size: 15px;
                        color: #AAAAAA;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }

                HorizontalLayout {
                    spacing: 12px;
                    
                    // Cancelar
                    Rectangle {
                        height: 50px;
                        horizontal-stretch: 1;
                        border-radius: 25px;
                        background: #333333;
                        Text {
                            text: "Atrás";
                            color: #FFFFFF;
                            font-weight: 600;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.show-delete-dialog = false;
                            }
                        }
                    }

                    // Eliminar
                    Rectangle {
                        height: 50px;
                        horizontal-stretch: 1;
                        border-radius: 25px;
                        background: #FF4040;
                        Text {
                            text: "Eliminar";
                            color: #FFFFFF;
                            font-weight: 800;
                            vertical-alignment: center;
                            horizontal-alignment: center;
                        }

                        TouchArea {
                            clicked => {
                                root.delete-project(root.delete-target-index);
                                root.show-delete-dialog = false;
                            }
                        }
                    }
                }
            }
        }
    }
}
