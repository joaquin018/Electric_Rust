import { Button, VerticalBox, ScrollView } from "std-widgets.slint";
import { InventoryItem } from "../components/inventory_item.slint";
import { LumberItem } from "../components/lumber_item.slint";
import { SectionHeader } from "../components/section_header.slint";
import { TopBar } from "../components/top_bar.slint";
import {
    ElectricSelectionItem,
} from "../components/electric_selection_item.slint";

export component BaseScreen inherits Rectangle {
    in-out property <[string]> inv_vals;
    in-out property <[int]> inv_lengths; // indices parallel to inv_vals
    in-out property <int> active_idx;
    in property <string> project-name: "ELECTRIC";
    in-out property <length> viewport-y; // Exposed for scroll tracking
    callback selective-share-pressed();
    callback trash-pressed();
    callback request-activate-item(int);
    callback request-append-digit(string);
    callback request-set-length(int, int); // idx, length_idx
    callback request-backspace(); // New callback for Rust persistence

    VerticalLayout {
        TopBar {
            title: root.project-name;
            selective-share-pressed => {
                root.selective-share-pressed();
            }
            trash-pressed => {
                root.trash-pressed();
            }
        }

        Flickable {
            viewport-y <=> root.viewport-y;
            viewport-height: content.preferred-height;
            content := VerticalBox {
                padding-left: 16px;
                padding-right: 16px;
                padding-bottom: 350px;
                spacing: 12px;
                alignment: start;
                SectionHeader {
                    title: "EMPALME";
                }

                InventoryItem {
                    label: "Caja Empalme";
                    value: root.inv_vals[0];
                    has-focus: root.active_idx == 0;
                    request-focus => {
                        root.request-activate-item(0);
                    }
                }

                InventoryItem {
                    label: "Medidor Monofásico";
                    value: root.inv_vals[1];
                    has-focus: root.active_idx == 1;
                    request-focus => {
                        root.request-activate-item(1);
                    }
                }

                InventoryItem {
                    label: "Concentrico 2x6";
                    value: root.inv_vals[2];
                    has-focus: root.active_idx == 2;
                    request-focus => {
                        root.request-activate-item(2);
                    }
                }

                InventoryItem {
                    label: "Grampa Retención";
                    value: root.inv_vals[3];
                    has-focus: root.active_idx == 3;
                    request-focus => {
                        root.request-activate-item(3);
                    }
                }

                InventoryItem {
                    label: "Conector Dentado";
                    value: root.inv_vals[4];
                    has-focus: root.active_idx == 4;
                    request-focus => {
                        root.request-activate-item(4);
                    }
                }

                InventoryItem {
                    label: "Conector UDC";
                    value: root.inv_vals[5];
                    has-focus: root.active_idx == 5;
                    request-focus => {
                        root.request-activate-item(5);
                    }
                }

                ElectricSelectionItem {
                    label: "Preensamblado";
                    value: root.inv_vals[6];
                    has-focus: root.active_idx == 6;
                    selected-index: root.inv_lengths[6];
                    options: ["2x16", "2x25"];
                    request-focus => {
                        root.request-activate-item(6);
                    }
                    set-index(i) => {
                        root.request-set-length(6, i);
                    }
                }

                SectionHeader {
                    title: "PUESTA A TIERRA Y ACOMETIDA";
                }

                InventoryItem {
                    label: "Automático 25A";
                    value: root.inv_vals[7];
                    has-focus: root.active_idx == 7;
                    request-focus => {
                        root.request-activate-item(7);
                    }
                }

                InventoryItem {
                    label: "Barra Copperweld";
                    value: root.inv_vals[8];
                    has-focus: root.active_idx == 8;
                    request-focus => {
                        root.request-activate-item(8);
                    }
                }

                InventoryItem {
                    label: "Prensa para Barra";
                    value: root.inv_vals[9];
                    has-focus: root.active_idx == 9;
                    request-focus => {
                        root.request-activate-item(9);
                    }
                }

                InventoryItem {
                    label: "Cámara Registro 160mm";
                    value: root.inv_vals[10];
                    has-focus: root.active_idx == 10;
                    request-focus => {
                        root.request-activate-item(10);
                    }
                }

                InventoryItem {
                    label: "Cañeria Zincada 5/8";
                    value: root.inv_vals[11];
                    has-focus: root.active_idx == 11;
                    request-focus => {
                        root.request-activate-item(11);
                    }
                }

                InventoryItem {
                    label: "Abrazadera Caddy";
                    value: root.inv_vals[12];
                    has-focus: root.active_idx == 12;
                    request-focus => {
                        root.request-activate-item(12);
                    }
                }

                InventoryItem {
                    label: "Cabeza de Servicio";
                    value: root.inv_vals[13];
                    has-focus: root.active_idx == 13;
                    request-focus => {
                        root.request-activate-item(13);
                    }
                }
            }
        }
    }
}
